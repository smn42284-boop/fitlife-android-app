<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_fitness"
        app:tint="@color/primary_light"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/TextTitleMedium"
        android:text="@string/start_your_journey"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <!-- Simple Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/TextBodyMedium"
        android:text="@string/sign_up_to_unlock"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Sign Up Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/signUpBtn"
        style="@style/MainButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sign_up"
        android:layout_marginBottom="12dp"
        app:icon="@drawable/ic_person"
        app:iconGravity="textStart" />

    <!-- Browse Workouts Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/browseWorkoutsBtn"
        style="@style/OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/browse_workouts"
        app:icon="@drawable/ic_search"
        app:iconGravity="textStart" />

</LinearLayout>