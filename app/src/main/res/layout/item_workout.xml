<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    style="@style/CardStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/workoutImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/workout_placeholder" />

            <TextView
                android:id="@+id/customBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CUSTOM"
                android:textSize="10sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_badge_background"
                android:textColor="@color/secondary_dark"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/workoutName"
                    style="@style/TextTitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/workout_full_body"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/workoutDuration"
                    style="@style/TextLabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_45_min"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/duration_badge"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <!-- Category Chips -->
            <LinearLayout
                android:id="@+id/categoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <com.google.android.material.chip.Chip
                    android:id="@+id/categoryChip"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/strength"
                    app:chipBackgroundColor="@color/primary_container"
                    app:chipIcon="@drawable/ic_fitness"
                    app:chipIconTint="@color/primary" />
            </LinearLayout>

            <!-- Exercises Preview -->
            <TextView
                android:id="@+id/exercisesPreview"
                style="@style/TextLabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exercises_preview_placeholder"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- Equipment Preview -->
            <TextView
                android:id="@+id/equipmentPreview"
                style="@style/TextLabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/equipment_preview_placeholder"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="12dp" />



            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/addButton"
                    style="@style/TextLabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/add_to_plan"
                    android:textColor="@color/on_primary"
                    android:gravity="center"
                    android:background="@drawable/add_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/removeButton"
                    style="@style/TextLabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/remove_from_plan"
                    android:textColor="@color/on_primary"
                    android:gravity="center"
                    android:background="@drawable/remove_button_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/menuButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_more_vert"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>