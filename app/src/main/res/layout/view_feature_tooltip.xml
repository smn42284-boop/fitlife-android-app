<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/tooltip_background"
    android:elevation="8dp"
    android:padding="0dp">

    <!-- Arrow pointing to target -->
    <View
        android:id="@+id/arrowUp"
        android:layout_width="20dp"
        android:layout_height="10dp"
        android:background="@drawable/tooltip_arrow_up"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/tooltip_content_background">

        <TextView
            android:id="@+id/titleText"
            style="@style/TextTitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/discover_workouts"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/descriptionText"
            style="@style/TextBodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tooltip_description"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/stepIndicator"
                style="@style/TextLabelSmall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/step_indicator_placeholder"
                android:textColor="@color/text_hint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/skipBtn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/skip"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nextBtn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/next"
                android:textColor="@color/primary" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/arrowDown"
        android:layout_width="20dp"
        android:layout_height="10dp"
        android:background="@drawable/tooltip_arrow_down"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

</LinearLayout>