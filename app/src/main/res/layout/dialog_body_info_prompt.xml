<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_fitness"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        app:tint="@color/primary" />

    <TextView
        style="@style/TextHeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/complete_your_profile"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        style="@style/TextBodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/body_info_prompt_message"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="2dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addInfoBtn"
        style="@style/MainButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/add_my_information"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/laterBtn"
        style="@style/OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/later" />

</LinearLayout>