<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_calendar"
        app:tint="@color/text_hint"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/emptyTitle"
        style="@style/TextTitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_workouts_planned"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/emptyMessage"
        style="@style/TextBodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_workouts_planned_message"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/browseWorkoutsBtn"
        style="@style/MainButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/browse_workouts"
        app:icon="@drawable/ic_fitness"
        app:iconGravity="textStart"/>
</LinearLayout>