<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="0dp">

    <!-- Hero Image -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/exerciseImage"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_fitness"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/exerciseName"
            style="@style/TextTitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pushups_placeholder"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/exerciseDetails"
            style="@style/TextLabelMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sets_reps_placeholder"
            android:textColor="@color/primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/exerciseInstructions"
            style="@style/TextBodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pushups_short_instructions"
            android:lineSpacingExtra="4dp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>