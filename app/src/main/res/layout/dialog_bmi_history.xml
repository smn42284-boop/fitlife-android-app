<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Current BMI Section -->
    <TextView
        style="@style/TextLabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CURRENT BMI"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bmi_gradient_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp">

        <TextView
            android:id="@+id/currentBmi"
            style="@style/TextDisplayMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--"
            android:textColor="@color/on_primary"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/currentStatus"
            style="@style/TextBodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="@color/on_primary"
            android:background="@drawable/bmi_status_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Last Updated -->
    <TextView
        android:id="@+id/lastUpdated"
        style="@style/TextLabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last updated: --"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <!-- BMI Range Info -->
    <TextView
        style="@style/TextLabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BMI CATEGORIES"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/bmiRange"
        style="@style/TextBodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <!-- History Timeline -->
    <TextView
        style="@style/TextLabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HISTORY"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/historyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>