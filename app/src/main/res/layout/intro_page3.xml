<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_shield"
        android:tint="@color/primary"
        android:layout_marginBottom="32dp"/>

    <TextView
        style="@style/TextHeadlineMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/secure_your_account"
        android:textColor="@color/primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        style="@style/TextBodyLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/secure_account_description"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/enable2FABtn"
        style="@style/MainButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/enable_2fa_now"/>

    <TextView
        android:id="@+id/remindLaterBtn"
        style="@style/TextLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/remind_me_later"
        android:padding="16dp"/>
</LinearLayout>