<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_shield"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        app:tint="@color/primary" />

    <TextView
        style="@style/TextHeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Protect Your Account"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        style="@style/TextBodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable two-factor authentication to add an extra layer of security to your account."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/setupNowBtn"
        style="@style/MainButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Set Up Now"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/laterBtn"
        style="@style/TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Do Later" />

</LinearLayout>