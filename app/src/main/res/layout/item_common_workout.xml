<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    style="@style/CardStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@color/surface_variant">

            <ImageView
                android:id="@+id/workoutImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/workout_placeholder" />

            <TextView
                android:id="@+id/completedBadge"
                style="@style/TextLabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/done_upper"
                android:textStyle="bold"
                android:textColor="@color/on_primary"
                android:background="@drawable/badge_completed"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_gravity="end|top"
                android:layout_margin="12dp"
                android:visibility="gone" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/workoutName"
                    style="@style/TextTitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/workout_full_body"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/workoutDuration"
                    style="@style/TextLabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_45_min"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/duration_badge"
                    android:textColor="@color/primary" />

                <ImageView
                    android:id="@+id/menuButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_more_vert"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="8dp"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <!-- Exercises Preview -->
            <TextView
                android:id="@+id/exercisesPreview"
                style="@style/TextLabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exercises_preview_placeholder"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <!-- Equipment Preview -->
            <TextView
                android:id="@+id/equipmentPreview"
                style="@style/TextLabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/equipment_preview_placeholder"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/actionButtonsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
               />
            <TextView
                android:id="@+id/completedText"
                style="@style/TextBodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/completed_check"
                android:textStyle="bold"
                android:textColor="@color/success"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="@color/success_container"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>