<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:gravity="center_vertical">

    <!-- Equipment Icon -->
    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="12dp">

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:backgroundTint="@color/primary_container" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_checklist"
            app:tint="@color/primary" />
    </FrameLayout>

    <!-- Equipment Name -->
    <TextView
        android:id="@+id/equipmentName"
        style="@style/TextBodyMedium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Dumbbells"
        android:textColor="@color/text_primary" />

    <!-- Optional: Quantity or Count -->
    <TextView
        android:id="@+id/equipmentCount"
        style="@style/TextLabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2x"
        android:textColor="@color/text_hint"
        android:visibility="gone" />

</LinearLayout>