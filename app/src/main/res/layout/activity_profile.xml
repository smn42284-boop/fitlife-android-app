<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <include layout="@layout/toolbar_base" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Header - Bigger and Centered -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Profile Image - Larger -->
                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/ic_profile_placeholder"
                            android:scaleType="centerCrop"
                            android:background="@drawable/profile_circle_background"
                            android:clipToOutline="true" />

                        <!-- Edit Icon Overlay -->
                        <LinearLayout
                            android:id="@+id/editProfileBtn"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/circle_background"
                            android:backgroundTint="@color/primary"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_edit"
                                app:tint="@color/on_primary" />
                        </LinearLayout>
                    </FrameLayout>

                    <!-- User Name - Larger -->
                    <TextView
                        android:id="@+id/userName"
                        style="@style/TextHeadlineMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textAlignment="center" />

                    <!-- User Email -->
                    <TextView
                        android:id="@+id/userEmail"
                        style="@style/TextBodyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="user@example.com"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BMI Status Card - Click to Edit -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bmiCard"
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            style="@style/TextLabelSmall"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Current Body Status"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/editBodyInfoBtn"
                            style="@style/TextLabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textColor="@color/primary"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- BMI Value with Ring -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_marginEnd="20dp">

                            <View
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/bmi_ring_background" />

                            <TextView
                                android:id="@+id/bmiValue"
                                style="@style/TextHeadlineMedium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="--"
                                android:textColor="@color/primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/bmiStatus"
                                style="@style/TextTitleMedium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:background="@drawable/bmi_status_badge"
                                android:paddingHorizontal="16dp"
                                android:paddingVertical="8dp"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/bmiDescription"
                                style="@style/TextBodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Daily Calorie Goal - Centered & Prominent -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/primary_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_fitness"
                        app:tint="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        style="@style/TextLabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DAILY CALORIE GOAL"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/calorieValue"
                        style="@style/TextDisplayMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/primary"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/calorieDescription"
                        style="@style/TextBodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Based on your profile"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BMI History Card - Simple Version -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bmiHistoryCard"
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:tint="@color/primary"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            style="@style/TextTitleSmall"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BMI History"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/viewHistoryBtn"
                            style="@style/TextLabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <!-- Simple BMI Progress Indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/lastBMIText"
                            style="@style/TextBodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last recorded: --"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="8dp" />

                        <!-- Simple bar showing progress -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@color/surface_variant"
                            android:padding="12dp"
                            android:layout_marginTop="8dp"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/currentBmiPreview"
                                style="@style/TextDisplaySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/primary"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/TextLabelSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Current BMI"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- Tip of the Day Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="💡"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextLabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIP OF THE DAY"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tipText"
                            style="@style/TextBodySmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drink water before meals to feel fuller and eat less."
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutBtn"
                style="@style/OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Logout"
                app:iconGravity="textStart"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>