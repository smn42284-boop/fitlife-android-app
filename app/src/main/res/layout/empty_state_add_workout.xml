<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/background">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_fitness"
        app:tint="@color/primary_light"
        android:layout_marginBottom="16dp"/>

    <TextView
        style="@style/TextTitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_to_fitlife"
        android:layout_marginBottom="8dp"/>

    <TextView
        style="@style/TextBodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_workouts_yet"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addWorkoutBtn"
        style="@style/MainButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/create_first_workout"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"/>
</LinearLayout>