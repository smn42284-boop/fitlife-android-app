<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Gestures"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/gestureSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Swipe left/right, shake, long press"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/gestureInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="• Swipe right: Mark workout complete\n• Swipe left: Remove from day\n• Shake: Reset workout progress\n• Long press: Share workout"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

</LinearLayout>