<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Illustration Container -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="40dp">

        <!-- Gradient Circle Background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/intro_circle_gradient"
            android:alpha="0.15" />

        <!-- Icon -->
        <ImageView
            android:id="@+id/illustration"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_fitness"
            app:tint="@color/primary" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        style="@style/TextHeadlineMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discover Workouts"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/descriptionText"
        style="@style/TextBodyLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Browse hundreds of workouts. From strength to yoga, find what suits you best."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="4dp" />

</LinearLayout>