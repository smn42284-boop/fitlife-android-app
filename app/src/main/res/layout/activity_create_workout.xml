<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <include layout="@layout/toolbar_base" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/imageCard"
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardElevation="1dp">

                <FrameLayout
                    android:id="@+id/imagePickerContainer"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/workoutImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/workout_placeholder"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/addImageContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface_variant"
                        android:visibility="visible">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_add_photo"
                            app:tint="@color/primary" />

                        <TextView
                            android:id="@+id/addImageText"
                            style="@style/TextBodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_workout_image"
                            android:textColor="@color/primary"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/TextTitleMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/basic_information"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nameLayout"
                style="@style/TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/workout_name"
                app:startIconDrawable="@drawable/ic_fitness"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/descriptionLayout"
                style="@style/TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/description"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descriptionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/durationLayout"
                style="@style/TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/duration"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/durationInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ================= SCHEDULE SECTION ================= -->
            <TextView
                style="@style/TextTitleMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/schedule"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/daysCard"
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="4dp"
                        android:background="@color/primary_container"
                        app:tint="@color/primary"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextBodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/workout_days"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/selectedDaysText"
                            style="@style/TextLabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no_days_selected"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= EXERCISES SECTION ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <!-- Header with count badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        style="@style/TextTitleMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/exercises"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/exerciseCount"
                        style="@style/TextLabelMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/zero_selected"
                        android:background="@color/surface_variant"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:gravity="center"
                        android:textColor="@color/primary"
                        app:cornerRadius="16dp" />
                </LinearLayout>

                <!-- Empty State (when no exercises) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/emptyExercisesCard"
                    style="@style/CardStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_variant"
                    app:cardElevation="0dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_fitness"
                            app:tint="@color/text_hint"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            style="@style/TextBodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No exercises added yet"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/TextLabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap 'Add Exercise' to get started"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Selected Exercises List -->
                <LinearLayout
                    android:id="@+id/selectedExercisesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp" />

                <!-- Add Exercise Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addExerciseBtn"
                    style="@style/OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/add_exercise"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- ================= EQUIPMENT SECTION (REDESIGNED) ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <!-- Header with count badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        style="@style/TextTitleMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/equipment"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/equipmentCount"
                        style="@style/TextLabelMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/zero_selected"
                        android:background="@color/surface_variant"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:gravity="center"
                        android:textColor="@color/primary"
                        app:cornerRadius="16dp" />
                </LinearLayout>

                <!-- Empty State (when no equipment) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/emptyEquipmentCard"
                    style="@style/CardStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface_variant"
                    app:cardElevation="0dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_checklist"
                            app:tint="@color/text_hint"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            style="@style/TextBodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No equipment added yet"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/TextLabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap 'Add Equipment' to get started"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Selected Equipment List -->
                <LinearLayout
                    android:id="@+id/selectedEquipmentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp" />

                <!-- Add Equipment Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addEquipmentBtn"
                    style="@style/OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/add_equipment"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/cancelBtn"
                    style="@style/OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cancel"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/saveBtn"
                    style="@style/MainButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/save_workout" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>