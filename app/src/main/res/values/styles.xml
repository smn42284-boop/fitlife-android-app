<resources>

    <declare-styleable name="FontFamily">
        <attr name="fontFamilyRegular" format="reference" />
        <attr name="fontFamilyMedium" format="reference" />
        <attr name="fontFamilyBold" format="reference" />
        <attr name="fontFamilyLight" format="reference" />
    </declare-styleable>


    <style name="TextDisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">57sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextDisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">45sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextDisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextHeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextHeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextHeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextTitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextTitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextTitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="TextTitle" parent="TextTitleLarge">
    </style>

    <style name="TextLabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="TextLabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextLabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <style name="TextBodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextBodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="TextBodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <!-- ALIAS for backward compatibility (FIXES YOUR ERRORS) -->
    <style name="TextSmall" parent="TextBodySmall">
        <!-- Used by existing layouts -->
    </style>

    <!-- Subtitle (ALIAS for backward compatibility) -->
    <style name="TextSubtitle" parent="TextBodyMedium">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <!-- Links -->
    <style name="TextLink" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Large Title (FIXES YOUR ERRORS) -->
    <style name="LargeTitle" parent="TextHeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ================= INPUT ================= -->
    <style name="TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="startIconTint">@color/input_icon_selector</item>
        <item name="endIconTint">@color/input_icon_selector</item>
        <item name="boxStrokeColor">@color/input_stroke_selector</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/input_hint_selector</item>
        <item name="android:textColorHint">@color/input_hint_selector</item>
        <item name="placeholderTextColor">@color/text_hint</item>
        <item name="helperTextTextColor">@color/text_secondary</item>
        <item name="errorTextColor">@color/error</item>
        <item name="errorIconTint">@color/error</item>
    </style>

    <!-- ================= BUTTONS ================= -->
    <style name="MainButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">@color/primary_light</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="backgroundTint">@color/secondary</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="rippleColor">@color/primary_container</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_secondary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cornerRadius">28dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">40dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="rippleColor">@color/primary_container</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/poppins_medium</item>
    </style>

    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">12dp</item>
    </style>

    <!-- ================= TOOLBAR ================= -->
    <style name="ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="ToolbarSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/ToolbarTitle</item>
        <item name="subtitleTextAppearance">@style/ToolbarSubtitle</item>
        <item name="android:background">@color/surface</item>
    </style>

    <!-- ================= BOTTOM NAVIGATION ================= -->
    <style name="Widget.FitLife.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemRippleColor">@color/primary_light</item>
        <item name="itemActiveIndicatorStyle">@style/BottomNavIndicator</item>
        <item name="itemIconSize">24dp</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="BottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
        <item name="android:height">32dp</item>
        <item name="android:width">32dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>

    <style name="MaterialDialog" parent="@style/ThemeOverlay.Material3">
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Large</item>
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:background">@color/surface</item>
    </style>

    <style name="MaterialDialog.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="fontFamily">@font/poppins_bold</item>
    </style>

    <style name="MaterialDialog.Message" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="fontFamily">@font/poppins_regular</item>
    </style>
    <style name="CheckboxSecondary" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/checkbox_selector</item>
    </style>
    <!-- Small Action Button (for Start and Details) -->
    <style name="ActionButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Start Button (Filled with Primary Color) -->
    <style name="StartButton" parent="ActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="rippleColor">@color/primary_light</item>
        <item name="iconTint">@color/on_primary</item>
    </style>

    <!-- Details Button (Outlined) -->
    <style name="DetailsButton" parent="ActionButton">
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/primary</item>
        <item name="rippleColor">@color/primary_container</item>
        <item name="iconTint">@color/primary</item>
    </style>
    <!-- ================= CHECKBOX STYLES ================= -->
    <style name="CheckboxStyle" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/checkbox_selector</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Compact Checkbox (for dialogs) -->
    <style name="CheckboxCompact" parent="CheckboxStyle">
        <item name="android:minWidth">40dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
    <style name="HomePageButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_weight">1</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="HomePageStartButton" parent="HomePageButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="iconTint">@color/on_primary</item>
    </style>

    <style name="HomePageDetailsButton" parent="HomePageButton">
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/primary</item>
        <item name="iconTint">@color/primary</item>
    </style>
    <!-- Dialog Animation -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

</resources>