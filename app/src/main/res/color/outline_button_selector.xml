<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:color="@color/primary_dark" android:state_pressed="true" />
    <!-- Focused state -->
    <item android:color="@color/primary" android:state_focused="true" />
    <!-- Hovered state (for TV/Desktop) -->
    <item android:color="@color/primary" android:state_hovered="true" />
    <!-- Default state -->
    <item android:color="@color/primary" />
</selector>